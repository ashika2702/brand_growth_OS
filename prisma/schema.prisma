generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  role            String   @default("account_manager")
  name            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  assignedClients Client[] @relation("ClientToUser")
}

model Client {
  id                     String               @id @default(cuid())
  name                   String
  domain                 String?
  logo                   String?
  primaryColor           String?              @default("#0D1117")
  brand24ProjectId       String?
  canvaBrandKitId        String?
  elevenlabsVoiceId      String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  canvaAccessToken       String?
  canvaRefreshToken      String?
  canvaTokenExpiresAt    DateTime?
  fromName               String?
  imapHost               String?
  imapPort               Int?
  smtpHost               String?
  smtpPass               String?
  smtpPort               Int?
  smtpUser               String?
  autoPilotMode          String               @default("manual")
  googleAdsKey           String?
  metaAccessToken        String?
  metaPageId             String?
  linkedInAccessToken    String?
  googleAccessToken      String?
  googleRefreshToken     String?
  googleSearchConsoleUrl String?
  googleTokenExpiresAt   DateTime?
  googleAnalyticsPropertyId String?
  googleTagManagerContainerId String?
  brain                  BusinessBrain?
  intelligence           ContentIntelligence?
  contentRequests        ContentRequest[]
  humanGates             HumanGate[]
  leads                  Lead[]
  leadForms              LeadForm[]
  sequences              NeuralSequence[]
  notifications          Notification[]
  prMentions             PRMention[]
  prOpportunities        PROpportunity[]
  prReleases             PRRelease[]
  SeoKeyword             SeoKeyword[]
  assignedUsers          User[]               @relation("ClientToUser")
}

model HumanGate {
  id             String    @id @default(cuid())
  clientId       String
  agentId        String?
  gateType       String
  question       String?
  contextJson    Json?
  optionsJson    Json?
  status         String    @default("pending")
  resolvedBy     String?
  resolvedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  leadId         String?
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead           Lead?     @relation(fields: [leadId], references: [id])

  @@index([clientId, status])
}

model ContentRequest {
  id              String    @id @default(cuid())
  clientId        String
  type            String
  platform        String[]
  status          String    @default("REQUESTED")
  title           String
  briefText       String?
  aiBrief         Json?
  campaign        String?
  dueDate         DateTime?
  assignedTo      String?
  priority        String    @default("medium")
  voiceScore      Int?
  performanceData Json?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  aiImageUrls     String[]  @default([])
  approvedAt      DateTime?
  canvaDesignUrl  String?
  publishAt       DateTime?
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
}

model ContentIntelligence {
  id        String   @id @default(cuid())
  clientId  String   @unique
  tips      String[]
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model BusinessBrain {
  id              String   @id @default(cuid())
  clientId        String   @unique
  personas        Json?
  offers          Json?
  salesJourney    Json?
  onlineChannels  String[]
  offlineChannels String[]
  proofAssets     Json?
  constraints     String[]
  messagingAngles Json?
  competitorIntel Json?
  updatedAt       DateTime @updatedAt
  voiceGuide      Json?
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model PRMention {
  id               String       @id @default(cuid())
  clientId         String
  brand24MentionId String?
  sourceType       String?
  url              String?
  title            String?
  snippet          String?
  sentiment        String?
  authorityScore   Int?
  reach            Int?
  classification   String?
  actionTaken      String?
  publishedAt      DateTime?
  detectedAt       DateTime     @default(now())
  client           Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  responses        PRResponse[]
}

model PRResponse {
  id         String    @id @default(cuid())
  mentionId  String
  clientId   String
  draftText  String
  status     String    @default("pending")
  approvedBy String?
  postedAt   DateTime?
  createdAt  DateTime  @default(now())
  mention    PRMention @relation(fields: [mentionId], references: [id], onDelete: Cascade)
}

model PROpportunity {
  id            String    @id @default(cuid())
  clientId      String
  type          String
  title         String
  description   String?
  draftPitch    String?
  sourceUrl     String?
  deadline      DateTime?
  status        String    @default("open")
  priorityScore Int?
  createdAt     DateTime  @default(now())
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model PRRelease {
  id           String   @id @default(cuid())
  clientId     String
  triggerEvent String?
  headline     String
  bodyMd       String
  status       String   @default("draft")
  createdBy    String?
  createdAt    DateTime @default(now())
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Lead {
  id                String           @id @default(cuid())
  clientId          String
  name              String
  email             String
  phone             String?
  source            String?
  personaTag        String?
  stage             String           @default("new")
  assignedTo        String?
  score             Int              @default(0)
  tags              String[]
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  emailOptOut       Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  lastActivityAt    DateTime         @default(now())
  lossReason        String?
  quotedValue       Int?
  scoreFactors      Json?
  intent            String?
  currentSequenceId String?
  isAutoPilotActive Boolean          @default(false)
  customFields      Json?
  addressCity       String?
  addressCountry    String?
  addressState      String?
  addressStreet     String?
  addressZip        String?
  description       String?
  formId            String?
  fbclid            String?
  gclid             String?
  li_fat_id         String?
  googleLeadId      String?
  liLeadId          String?
  metaLeadId        String?
  humanGates        HumanGate[]
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  form              LeadForm?        @relation(fields: [formId], references: [id])
  activities        LeadActivity[]
  attachments       LeadAttachment[]
  sequences         LeadSequence[]
  tasks             LeadTask[]
}

model LeadAttachment {
  id        String   @id @default(cuid())
  leadId    String
  fileName  String
  fileUrl   String
  fileType  String?
  fileSize  Int?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  type        String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadTask {
  id          String    @id @default(cuid())
  leadId      String
  type        String
  title       String
  description String?
  dueDate     DateTime
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  clientId  String?
  userId    String?
  type      String
  title     String
  message   String
  priority  String   @default("medium")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model NeuralSequence {
  id          String         @id @default(cuid())
  clientId    String
  name        String
  description String?
  steps       Json
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  leads       LeadSequence[]
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, name])
  @@index([clientId])
}

model LeadSequence {
  id          String         @id @default(cuid())
  leadId      String
  sequenceId  String
  status      String         @default("active")
  currentStep Int            @default(0)
  nextStepAt  DateTime
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lead        Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequence    NeuralSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([leadId, sequenceId])
}

model LeadForm {
  id          String   @id @default(cuid())
  clientId    String
  name        String
  slug        String   @unique
  questions   Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?
  leads       Lead[]
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model SeoKeyword {
  id            String    @id
  clientId      String
  keyword       String
  location      String?
  currentRank   Int?
  previousRank  Int?
  lastCheckedAt DateTime?
  history       Json?     @default("[]")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, keyword])
  @@index([clientId])
}
