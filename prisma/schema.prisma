generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("account_manager") // Alex, Max, Nova, Forge, Quinn, Oracle
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedClients Client[]
}

model Client {
  id                 String   @id @default(cuid())
  name               String
  domain             String?
  logo               String?
  primaryColor       String?  @default("#0D1117")
  brand24ProjectId   String?
  canvaBrandKitId    String?
  canvaAccessToken   String?
  canvaRefreshToken  String?
  canvaTokenExpiresAt DateTime?
  elevenlabsVoiceId  String?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Email Configuration (For Neural Auto-Pilot)
  smtpHost           String?
  smtpPort           Int?
  smtpUser           String?
  smtpPass           String?
  imapHost           String?
  imapPort           Int?
  fromName           String?

  brain              BusinessBrain?
  assignedUsers      User[]
  prMentions         PRMention[]
  prOpportunities    PROpportunity[]
  prReleases         PRRelease[]
  leads              Lead[]
  notifications      Notification[]
  contentRequests    ContentRequest[]
  intelligence       ContentIntelligence?
  sequences          NeuralSequence[]
  humanGates         HumanGate[]

  autoPilotMode      String   @default("manual") // 'manual' | 'autopilot'

  // Direct Ad Webhooks (M03)
  googleAdsKey       String?
  metaAccessToken    String?
  metaPageId         String?
  linkedInAccessToken String?
}

model HumanGate {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  leadId          String?
  lead            Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  agentId         String?  // 'CD'|'CP'|'A3'|'sequence' etc
  gateType        String   // 'information'|'approval'|'threshold'|'confidence'
  
  question        String?
  contextJson     Json?    // e.g. { draftSubject, draftHtml, leadId, sequenceId }
  optionsJson     Json?    
  
  status          String   @default("pending") // 'pending'|'approved'|'declined'|'overridden'
  
  resolvedBy      String?
  resolvedAt      DateTime?
  resolutionNote  String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId, status])
}

model ContentRequest {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  type            String   // Reel, Post, Story, Ad, Email, Blog, Page
  platform        String[] // IG, FB, LinkedIn, GBP, Email, Google
  status          String   @default("REQUESTED") // REQUESTED, BRIEFED, IN_PROD, REVIEW, APPROVED, PUBLISHED
  
  title           String
  briefText       String?  // The plain language brief from user
  aiBrief         Json?    // hooks[], script, captions[], CTAs[], image_prompt
  
  campaign        String?
  dueDate         DateTime?
  assignedTo      String?
  priority        String   @default("medium") // low, medium, high, urgent
  
  voiceScore      Int?
  performanceData Json?    // reach, engagement_rate, etc.
  
  canvaDesignUrl  String?
  aiImageUrls     String[] @default([])
  publishAt       DateTime?
  approvedAt      DateTime?
  
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId, status])
}

model ContentIntelligence {
  id        String   @id @default(cuid())
  clientId  String   @unique
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  tips      String[] // Array of intelligence tips
  updatedAt DateTime @updatedAt
}

model BusinessBrain {
  id               String   @id @default(cuid())
  clientId         String   @unique
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  personas         Json?    // Array of persona objects
  offers           Json?    // Array of offer objects
  salesJourney     Json?    
  onlineChannels   String[]
  offlineChannels  String[]
  proofAssets      Json?
  constraints      String[]
  messagingAngles  Json?
  competitorIntel  Json?
  voiceGuide       Json?    // { tone, adjectives[], vocab_do[], vocab_dont[], samples[] }

  updatedAt        DateTime @updatedAt
}

model PRMention {
  id               String   @id @default(cuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  brand24MentionId String?
  sourceType       String?  // 'news'|'social'|'blog'|'review'|'forum'
  url              String?
  title            String?
  snippet          String?
  sentiment        String?  // 'positive'|'negative'|'neutral'
  authorityScore   Int?
  reach            Int?
  classification   String?  // 'opportunity'|'threat'|'journalist'|'neutral'
  actionTaken      String?
  publishedAt      DateTime?
  detectedAt       DateTime @default(now())

  responses        PRResponse[]
}

model PRResponse {
  id               String   @id @default(cuid())
  mentionId        String
  mention          PRMention @relation(fields: [mentionId], references: [id], onDelete: Cascade)
  clientId         String
  draftText        String
  status           String   @default("pending") // 'pending'|'approved'|'posted'|'dismissed'
  approvedBy       String?
  postedAt         DateTime?
  createdAt        DateTime @default(now())
}

model PROpportunity {
  id               String   @id @default(cuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type             String   // 'haro'|'journalist'|'amplification'
  title            String
  description      String?
  draftPitch       String?
  sourceUrl        String?
  deadline         DateTime?
  status           String   @default("open")
  priorityScore    Int?
  createdAt        DateTime @default(now())
}

model PRRelease {
  id               String   @id @default(cuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  triggerEvent     String?  // 'award'|'launch'|'milestone'|'review_surge'
  headline         String
  bodyMd           String
  status           String   @default("draft") // 'draft'|'approved'|'distributed'
  createdBy        String?  // 'agent'|'manual'
  createdAt        DateTime @default(now())
}

model Lead {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name            String
  email           String
  phone           String?
  source          String?
  personaTag      String?
  stage           String   @default("new") // 'new'|'contacted'|'qualified'|'quoted'|'won'|'lost'
  assignedTo      String?
  score           Int      @default(0)
  scoreFactors    Json?    // Stores the sub-scores (persona_match, source_quality, behaviour, stage_velocity, offer_fit)
  intent          String?
  tags            String[]
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  emailOptOut     Boolean  @default(false)
  quotedValue     Int?     // Value of quote if stage is 'quoted' or 'won'
  lossReason      String?  // Reason if stage is 'lost'
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastActivityAt  DateTime @default(now())

  activities      LeadActivity[]
  tasks           LeadTask[]
  
  // Phase 4: Autonomous Sequences
  isAutoPilotActive Boolean @default(false)
  currentSequenceId String?
  sequences         LeadSequence[]
  humanGates        HumanGate[]
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        String   // 'call'|'email'|'whatsapp'|'note'|'stage_change'|'created'|'score_update'|'task_due'
  description String
  metadata    Json?    // Optional extra context (e.g., fromStage, toStage, messageBody)
  createdAt   DateTime @default(now())
}

model LeadTask {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        String   // 'call'|'email'|'whatsapp'|'visit'|'quote'
  title       String
  description String?
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String?
  type      String   // 'lead.new'|'content.awaiting_approval'|'seo.rank_drop'|'pr.negative_mention'|etc.
  title     String
  message   String
  priority  String   @default("medium") // 'low'|'medium'|'high'|'urgent'
  isRead    Boolean  @default(false)
  link      String?  // Actionable link
  createdAt DateTime @default(now())
}

model NeuralSequence {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  steps       Json     // Array of { delayDays: number, strategy: string, offerId?: string }
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  leads       LeadSequence[]

  @@index([clientId])
  @@unique([clientId, name])
}

model LeadSequence {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequenceId  String
  sequence    NeuralSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  
  status      String   @default("active") // active, paused, completed, stopped_by_reply
  currentStep Int      @default(0)
  nextStepAt  DateTime
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([leadId, sequenceId])
}
